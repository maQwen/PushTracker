# Keystore properties for signing APK releases
# IMPORTANT: Do not commit this file with real values to version control!
# Add this file to .gitignore and store sensitive values in GitHub Secrets

# Path to keystore file (relative to project root)
storeFile=keystore/release.keystore

# Keystore password
storePassword=your_keystore_password

# Key alias
keyAlias=your_key_alias

# Key password
keyPassword=your_key_password
